# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# HighLevel CRM
HIGHLEVEL_API_KEY=your_highlevel_api_key_here
HIGHLEVEL_LOCATION_ID=your_highlevel_location_id_here
HIGHLEVEL_CALENDAR_ID=your_highlevel_calendar_id_here
HIGHLEVEL_NATALIE_USER_ID=your_highlevel_natalie_user_id_here

# Upstash Redis (sessieopslag)
